# 必填：CallMesh API Key，沒有值將無法啟動
CALLMESH_API_KEY=

# Meshtastic 節點連線參數
MESHTASTIC_HOST=
MESHTASTIC_PORT=4403

# Web Dashboard 對外連接埠與啟用開關
TMAG_WEB_PORT=7080
TMAG_WEB_DASHBOARD=1
TMAG_TIMEZONE=Asia/Taipei

# TenManMap 分享開關（1=停用／0=啟用）
TENMAN_DISABLE=0

# Docker 自動更新設定
AUTO_UPDATE=0
AUTO_UPDATE_BRANCH=main
AUTO_UPDATE_REPO=https://github.com/oh001738/CMClient.git
AUTO_UPDATE_WORKDIR=/data/callmesh/app-src
AUTO_UPDATE_POLL_SECONDS=300

# TCP 代理共享連線設定 (TCP Proxy)
MESHTASTIC_PROXY=false
MESHTASTIC_PROXY_PORT=4403
MESHTASTIC_PROXY_HOST=127.0.0.1
